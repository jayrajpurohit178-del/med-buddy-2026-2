const API = "https://api.anthropic.com/v1/messages";
const MDL = "claude-sonnet-4-20250514";

const NAV = [
  { id:"dashboard",   icon:"grid",      label:"Dashboard"       },
  { id:"prescription",icon:"clipboard", label:"Prescription"    },
  { id:"expense",     icon:"wallet",    label:"Monthly Expense" },
  { id:"checklist",   icon:"check",     label:"Checklist"       },
  { id:"schedule",    icon:"calendar",  label:"Schedule"        },
  { id:"history",     icon:"clock",     label:"History"         },
  { id:"account",     icon:"user",      label:"Account"         },
];

const RX_SYS = `You are MedBuddy. Simplify prescriptions ONLY from what the doctor wrote. No extra advice, no alternatives.
Return ONLY valid JSON: {"patientName":"","diagnosis":"plain language","diagnosisSimple":"2-3 sentence explanation","medications":[{"name":"","dosage":"","timing":"","days":"","withFood":false}],"sideEffects":["",""],"emergencyWarning":"","followUpChecklist":{"tests":[],"diet":[],"activity":[],"followUpDate":null},"oneLiner":""}`;

const CHAT_SYS = `You are MedBuddy's friendly assistant. Help patients understand prescriptions in plain language. Never use jargon. Never suggest alternative medicines or new advice. Max 2-3 sentences per reply.`;

const DEMO = `Patient: Arjun Mehta, Age: 52
Diagnosis: Type 2 Diabetes Mellitus with mild hypertension
Rx:
1. Tab Metformin 500mg - 1-0-1 after meals x 30 days
2. Tab Amlodipine 5mg - 1-0-0 after breakfast x 30 days
3. Tab Atorvastatin 10mg - 0-0-1 after dinner x 30 days
4. Tab Aspirin 75mg - 0-1-0 after lunch x 30 days
Tests: FBS, HbA1c, Lipid profile, ECG
Diet: Low salt low sugar, no fried food, more vegetables
Activity: Walk 30 min daily, avoid heavy exercise
Follow-up: 2 weeks
Dr. Sunita Rao, MD Cardiology, Apollo Hospital`;

function parseJSON(txt) {
  try {
    const c = txt.replace(/```json|```/g,"").trim();
    return JSON.parse(c.slice(c.indexOf("{"), c.lastIndexOf("}")+1));
  } catch { return null; }
}

