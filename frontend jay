/* ─────────────────────────────────────────
   SMALL COMPONENTS
───────────────────────────────────────── */
const Spinner = ({size=20}) => (
  <div style={{width:size,height:size,border:`2.5px solid #c026d330`,borderTop:`2.5px solid #8b5cf6`,borderRadius:"50%",animation:"spin .7s linear infinite",display:"inline-block"}}/>
);

const Badge = ({label,bg,col}) => (
  <span style={{background:bg,color:col,fontSize:10,fontWeight:700,padding:"2px 9px",borderRadius:20,letterSpacing:.3}}>{label}</span>
);

const timingStyle = t => {
  const l=(t||"").toLowerCase();
  if(l.includes("morning")||l.includes("1-0-0"))return{bg:T.amberBg,col:T.amber,lbl:"Morning"};
  if(l.includes("afternoon")||l.includes("lunch")||l.includes("0-1-0"))return{bg:T.blueBg,col:T.blue,lbl:"Afternoon"};
  if(l.includes("night")||l.includes("dinner")||l.includes("0-0-1"))return{bg:T.purpleBg,col:T.purple,lbl:"Night"};
  return{bg:"#f3f4f6",col:T.sub,lbl:t||"As directed"};
};

/* ─────────────────────────────────────────
   MAIN APP
───────────────────────────────────────── */
export default function MedBuddy() {
  const [page,    setPage]    = useState("dashboard");
  const [thin,    setThin]    = useState(false);       // sidebar collapsed
  const [result,  setResult]  = useState(null);
  const [loading, setLoading] = useState(false);
  const [loadMsg, setLoadMsg] = useState("");
  const [err,     setErr]     = useState("");
  const [rawText, setRawText] = useState("");
  const [hist,    setHist]    = useState([]);
  const [isRec,   setIsRec]   = useState(false);
  const [audioTxt,setAudioTxt]= useState("");
  const [medRes,  setMedRes]  = useState(null);
  const [medLoad, setMedLoad] = useState(false);
  const [checks,  setChecks]  = useState({});
  const [notifPh, setNotifPh] = useState("");
  const [notifWa, setNotifWa] = useState("");
  const [notifOk, setNotifOk] = useState(false);
  const [lang,    setLang]    = useState("English"); // output language
  // chat
  const [msgs,    setMsgs]    = useState([{from:"bot",text:"Hi! I'm your MedBuddy assistant. Ask me anything about your prescription 😊"}]);
  const [chatIn,  setChatIn]  = useState("");
  const [chatLoad,setChatLoad]= useState(false);

  const fileRef   = useRef();
  const medRef    = useRef();
  const recRef    = useRef();
  const chatEnd   = useRef();

  const saveHist = d => setHist(p=>[{...d,savedAt:new Date().toISOString()},...p].slice(0,10));

  /* ── API helpers ── */
  const processText = async(text, outLang=lang)=>{
    setLoading(true); setErr(""); setLoadMsg("Reading document...");
    try {
      const langNote = `Please provide all plain-language explanations and the diagnosisSimple field in ${outLang}.`;
      const r=await fetch(API,{method:"POST",headers:{"Content-Type":"application/json"},
        body:JSON.stringify({model:MDL,max_tokens:1000,system:RX_SYS,messages:[{role:"user",content:`${langNote}\n\n${text}`}]})});
      const d=await r.json();
      setLoadMsg("Simplifying medical terms...");
      const p=parseJSON(d.content?.find(b=>b.type==="text")?.text||"");
      if(!p)throw new Error("Could not parse. Try pasting the text instead.");
      setResult({...p, outputLang:outLang}); saveHist({...p, outputLang:outLang}); setPage("prescription");
    } catch(e){setErr(e.message);}
    setLoading(false);
  };

  const handleFile = e=>{
    const f=e.target.files?.[0]; if(!f)return;
    const rd=new FileReader();
    rd.onload=async()=>{
      const b64=rd.result.split(",")[1];
      setLoading(true); setErr(""); setLoadMsg("Reading file...");
      try {
        const blk=f.type.startsWith("image/")
          ?{type:"image",source:{type:"base64",media_type:f.type,data:b64}}
          :{type:"document",source:{type:"base64",media_type:"application/pdf",data:b64}};
        const r=await fetch(API,{method:"POST",headers:{"Content-Type":"application/json"},
          body:JSON.stringify({model:MDL,max_tokens:1000,system:RX_SYS,
            messages:[{role:"user",content:[blk,{type:"text",text:"Extract and simplify. Handwritten text is fine."}]}]})});
        const d=await r.json();
        const p=parseJSON(d.content?.find(b=>b.type==="text")?.text||"");
        if(!p)throw new Error("Could not read file. Ensure the image is clear.");
        setResult(p); saveHist(p); setPage("prescription");
      } catch(e){setErr(e.message);}
      setLoading(false);
    };
    rd.readAsDataURL(f);
  };

  const handleMedPhoto = e=>{
    const f=e.target.files?.[0]; if(!f)return;
    const rd=new FileReader();
    rd.onload=async()=>{
      const b64=rd.result.split(",")[1];
      setMedLoad(true); setMedRes(null);
      try {
        const ctx=result?.medications?`Prescription context: ${JSON.stringify(result.medications)}`:"";
        const r=await fetch(API,{method:"POST",headers:{"Content-Type":"application/json"},
          body:JSON.stringify({model:MDL,max_tokens:1000,
            system:`Identify medicine from image. Return ONLY JSON: {"medicineName":"","purpose":"plain language what it does","commonFor":"","prescribedInfo":"","importantNote":""}`,
            messages:[{role:"user",content:[{type:"image",source:{type:"base64",media_type:f.type,data:b64}},{type:"text",text:`Identify this medicine. ${ctx}`}]}]})});
        const d=await r.json();
        const p=parseJSON(d.content?.find(b=>b.type==="text")?.text||"");
        setMedRes(p||{medicineName:"Unknown",purpose:"Could not identify."});
      } catch(e){setErr(e.message);}
      setMedLoad(false);
    };
    rd.readAsDataURL(f);
  };

  const startRec=()=>{
    const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
    if(!SR){setAudioTxt("Speech recognition not supported. Paste transcript below.");return;}
    const r=new SR(); r.continuous=true; r.interimResults=true;
    r.lang = lang==="Hindi" ? "hi-IN" : "en-IN";
    let t="";
    r.onresult=e=>{t=Array.from(e.results).map(x=>x[0].transcript).join(" ");setAudioTxt(t);};
    r.start(); recRef.current=r; setIsRec(true);
  };
  const stopRec=()=>{recRef.current?.stop();setIsRec(false);};

  const sendChat=async()=>{
    if(!chatIn.trim())return;
    const msg=chatIn.trim(); setChatIn("");
    const next=[...msgs,{from:"user",text:msg}];
    setMsgs(next); setChatLoad(true);
    try {
      const ctx=result?`Patient's prescription: ${JSON.stringify({diagnosis:result.diagnosis,medications:result.medications})}. `:"";
      const r=await fetch(API,{method:"POST",headers:{"Content-Type":"application/json"},
        body:JSON.stringify({model:MDL,max_tokens:1000,system:CHAT_SYS,messages:[{role:"user",content:ctx+msg}]})});
      const d=await r.json();
      const rep=d.content?.find(b=>b.type==="text")?.text||"Sorry, try again.";
      setMsgs([...next,{from:"bot",text:rep}]);
    } catch {setMsgs([...next,{from:"bot",text:"Oops! Something went wrong."}]);}
    setChatLoad(false);
    setTimeout(()=>chatEnd.current?.scrollIntoView({behavior:"smooth"}),100);
  };

  const chk=k=>setChecks(p=>({...p,[k]:!p[k]}));

  /* ════════════════════════════════════════
     LEFT SIDEBAR
  ════════════════════════════════════════ */
  const Sidebar = ()=>(
    <aside style={{
      width:thin?64:220, minHeight:"100vh", background:T.gradSide,
      display:"flex", flexDirection:"column", flexShrink:0,
      transition:"width .22s ease", overflow:"hidden", position:"relative", zIndex:10,
    }}>
      {/* Logo row */}
      <div style={{padding:"18px 14px 14px",borderBottom:`1px solid ${T.sbBdr}`,display:"flex",alignItems:"center",gap:10}}>
        <div style={{width:36,height:36,borderRadius:10,background:T.grad,display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" fill="white"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 14h-2v-6h2v6zm0-8h-2V6h2v2z" fill="white" opacity=".5"/></svg>
        </div>
        {!thin&&<div>
          <div style={{color:"#e0f2fe",fontWeight:700,fontSize:15,letterSpacing:"-.3px",fontFamily:"'DM Serif Display',Georgia,serif"}}>MedBuddy</div>
          <div style={{color:T.sbTxt,fontSize:10,marginTop:1}}>AI Prescription Helper</div>
        </div>}
      </div>

      {/* Collapse toggle */}
      <button onClick={()=>setThin(p=>!p)} style={{
        margin:"8px 10px",padding:"6px",background:"transparent",border:`1px solid ${T.sbBdr}`,
        borderRadius:7,color:T.sbTxt,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",
      }}>
        <Icon n={thin?"chevR":"chevL"} size={14} col={T.sbTxt}/>
      </button>

      {/* Nav */}
      <nav style={{flex:1,paddingTop:4}}>
        {NAV.map(item=>(
          <button key={item.id} onClick={()=>setPage(item.id)} title={thin?item.label:""} style={{
            width:"100%",display:"flex",alignItems:"center",gap:12,
            padding:thin?"10px 20px":"10px 16px",
            background:page===item.id?"rgba(14,165,233,0.18)":"transparent",
            border:"none",borderLeft:page===item.id?`3px solid #38bdf8`:"3px solid transparent",
            color:page===item.id?T.sbTxtAct:T.sbTxt,
            cursor:"pointer",fontSize:13,fontWeight:page===item.id?600:400,
            textAlign:"left",transition:"all .14s",whiteSpace:"nowrap",
          }}>
            <Icon n={item.icon} size={17} col={page===item.id?"#38bdf8":T.sbTxt}/>
            {!thin&&<span>{item.label}</span>}
          </button>
        ))}
      </nav>

      {/* Bottom hint */}
      {!thin&&<div style={{padding:"12px 16px",borderTop:`1px solid ${T.sbBdr}`}}>
        <div style={{fontSize:10,color:T.sbTxt,lineHeight:1.5}}>IAR Udaan Hackathon 2026</div>
      </div>}
    </aside>
  );

  /* ════════════════════════════════════════
     TOPBAR
  ════════════════════════════════════════ */
  const Topbar = ()=>(
    <div style={{height:52,background:T.card,borderBottom:`1px solid ${T.brd}`,display:"flex",alignItems:"center",justifyContent:"space-between",padding:"0 20px",flexShrink:0,borderTop:`3px solid transparent`,backgroundImage:`${T.card},${T.grad}`,backgroundOrigin:"border-box",backgroundClip:"padding-box,border-box"}}>
      <div style={{fontWeight:700,fontSize:15,color:T.ink,fontFamily:"'DM Serif Display',Georgia,serif"}}>
        {NAV.find(n=>n.id===page)?.label||"Dashboard"}
      </div>
      <div style={{display:"flex",alignItems:"center",gap:10}}>
        {result&&<Badge label={`${result.medications?.length||0} medicines`} bg={T.grnBg} col={T.grnD}/>}
        {result&&<Badge label={result.patientName||"Patient"} bg="#f3f0ff" col={T.grnD}/>}
      </div>
    </div>
  );

  /* ════════════════════════════════════════
     PAGE VIEWS
  ════════════════════════════════════════ */

  /* ── Dashboard ── */
  const Dashboard=()=>(
    <div style={{display:"flex",flexDirection:"column",gap:16}}>

      {/* Error banner */}
      {err&&<div style={{background:T.redBg,border:`1px solid ${T.red}30`,borderRadius:10,padding:"10px 14px",fontSize:13,color:T.red,display:"flex",justifyContent:"space-between"}}>
        <span>{err}</span><button onClick={()=>setErr("")} style={{background:"none",border:"none",color:T.red,cursor:"pointer",fontSize:16}}>×</button>
      </div>}

      {/* ── Row A: Upload doc/pdf/photo ── */}
      <div style={{background:T.card,border:`1px solid ${T.brd}`,borderRadius:14,overflow:"hidden"}}>
        <div style={{padding:"14px 18px",borderBottom:`1px solid ${T.brd}`,display:"flex",alignItems:"center",justifyContent:"space-between"}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <Icon n="upload" size={16} col={T.grn}/>
            <span style={{fontWeight:700,fontSize:14,color:T.ink}}>Upload doc / PDF / Photo</span>
          </div>
          <button onClick={()=>medRef.current?.click()} style={{
            display:"flex",alignItems:"center",gap:6,padding:"6px 12px",
            background:T.grad,border:"none",borderRadius:8,fontSize:12,fontWeight:600,color:"#fff",cursor:"pointer"
          }}>
            <Icon n="photo" size={13} col="#fff"/> Med Photo
          </button>
          <input ref={medRef} type="file" accept="image/*" style={{display:"none"}} onChange={handleMedPhoto}/>
        </div>

        <div style={{padding:18}}>
          {/* Drop zone */}
          <div onClick={()=>fileRef.current?.click()} style={{
            border:`2px dashed #7dd3fc`,borderRadius:12,padding:"24px 16px",textAlign:"center",
            cursor:"pointer",background:T.gradSoft,marginBottom:14,transition:"opacity .15s"
          }}>
            <div style={{width:44,height:44,borderRadius:12,background:T.grad,display:"flex",alignItems:"center",justifyContent:"center",margin:"0 auto 10px"}}>
              <Icon n="upload" size={22} col="#fff"/>
            </div>
            <div style={{fontWeight:600,fontSize:14,color:T.ink}}>Click to upload prescription</div>
            <div style={{fontSize:12,color:T.mute,marginTop:3}}>PDF, JPG, PNG — printed or handwritten</div>
            <input ref={fileRef} type="file" accept=".pdf,image/*" style={{display:"none"}} onChange={handleFile}/>
          </div>

          <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:12}}>
            <div style={{flex:1,height:1,background:T.brd}}/><span style={{fontSize:11,color:T.mute}}>or paste text</span><div style={{flex:1,height:1,background:T.brd}}/>
          </div>

          {/* Output language selector */}
          <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:10,background:T.grnBg,borderRadius:10,padding:"8px 12px",border:`1px solid ${T.brd}`}}>
            <span style={{fontSize:11,fontWeight:700,color:T.grnD,letterSpacing:.4,textTransform:"uppercase"}}>📤 Output Language</span>
            <div style={{display:"flex",borderRadius:7,border:`1px solid ${T.brd2}`,overflow:"hidden"}}>
              {["English","Hindi"].map(l=>(
                <button key={l} onClick={()=>setLang(l)} style={{
                  padding:"5px 16px",fontSize:11,fontWeight:700,border:"none",cursor:"pointer",
                  background:lang===l?T.gradBtn:T.card,
                  color:lang===l?"#fff":T.grnD,
                  transition:"all .15s"
                }}>{l==="Hindi"?"हिंदी":"English"}</button>
              ))}
            </div>
          </div>

          <textarea value={rawText} onChange={e=>setRawText(e.target.value)}
            placeholder="Paste prescription text here..."
            style={{width:"100%",minHeight:72,padding:"10px 12px",fontSize:13,borderRadius:9,border:`1px solid ${T.brd2}`,resize:"vertical",boxSizing:"border-box",fontFamily:"inherit",color:T.ink,background:"#fafafa"}}/>

          <div style={{display:"flex",gap:8,marginTop:10}}>
            <button onClick={()=>processText(rawText)} disabled={!rawText.trim()||loading} style={{
              flex:1,padding:"10px",background:rawText.trim()&&!loading?T.gradBtn:"#e5e7eb",
              color:rawText.trim()&&!loading?"#fff":T.mute,border:"none",borderRadius:9,
              fontSize:13,fontWeight:700,cursor:rawText.trim()?"pointer":"default",display:"flex",alignItems:"center",justifyContent:"center",gap:8
            }}>
              {loading?<><Spinner size={16}/> {loadMsg}</>:"Simplify Prescription"}
            </button>
            <button onClick={()=>processText(DEMO)} disabled={loading} style={{
              padding:"10px 16px",background:"transparent",border:`1px solid ${T.brd2}`,
              borderRadius:9,fontSize:13,cursor:"pointer",color:T.sub,fontWeight:500
            }}>Try Demo</button>
          </div>
        </div>
      </div>

      {/* Med photo result */}
      {(medLoad||medRes)&&(
